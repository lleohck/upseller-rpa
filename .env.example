# URLs
UPSELLER_BASE_URL=https://app.upseller.com/
UPSELLER_LOGIN_URL=https://app.upseller.com/login
UPSELLER_PROTECTED_URL=https://app.upseller.com/
UPSELLER_DRAFT_URL=https://app.upseller.com/pt/products/mercado/up-edit/SEU_ID?dataType=2

# Credenciais
UPSELLER_USERNAME=seu_usuario
UPSELLER_PASSWORD=sua_senha

# Execucao
HEADFUL=true
CHROME_CDP_URL=http://127.0.0.1:9222
STORAGE_STATE_PATH=storage_state.json
UPSELLER_ACTION_TIMEOUT_MS=30000
UPSELLER_KEEP_OPEN=false
UPSELLER_KEEP_OPEN_SECONDS=90
UPSELLER_MAXIMIZE_WINDOW=true
UPSELLER_SKIP_VARIANT_CREATION=false

# POC de variante
UPSELLER_VARIANT_NAME=Cor
UPSELLER_OPTION_NAME=teste2
UPSELLER_OPTION_NAMES=teste2,teste3,teste4
UPSELLER_OPTION_DESCRIPTION_TEMPLATE=Descricao da opcao {{OPTION_NAME}} xxxxxxxx
UPSELLER_OPTION_PRICE_BRL=99,90
UPSELLER_APPLY_VARIANT_IMAGES=false

# Opcional: marcador de area autenticada (ex.: avatar/menu do usuario apos login)
UPSELLER_AUTH_SUCCESS_SELECTOR=span.user_name

# Opcional: seletores para detectar CAPTCHA e pausar para intervencao manual
UPSELLER_CAPTCHA_SELECTORS=span.inp_placeholder:has-text('CAPTCHA'),button.code_btn.send_code_btn,button.code_btn img[alt='CAPTCHA']

# Opcional: seletores de tela intermediaria apos login (ex.: confirmacao de e-mail)
UPSELLER_POST_LOGIN_BLOCKING_SELECTORS=

# Opcional: palavras-chave na URL que indicam etapa pendente apos login
UPSELLER_POST_LOGIN_BLOCKING_URL_KEYWORDS=verification,verify-email,confirm-email,email-confirm,confirmacao-email,validar-email

# Opcional: sobrescreva seletores padrao (lista separada por virgula)
# TODO: ajuste com seletores reais da UpSeller para maior confiabilidade
UPSELLER_USERNAME_SELECTORS=input[data-gtm-form-interact-field-id='0'],input.ant-input[type='text']
UPSELLER_PASSWORD_SELECTORS=input[data-gtm-form-interact-field-id='1'],input.ant-input[type='password']
UPSELLER_SUBMIT_SELECTORS=
